{
  "compilerOptions": {
    "baseUrl": "./",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@components/*": [
        "./components/*"
      ],
      "@scripts/*": [
        "./scripts/*"
      ],
      "@assets/*": [
        "./assets/*"
      ]
    }
  },
  "include": [
    "./components/**/*",
    "./scripts/**/*",
    "./assets/**/*",
    "./app/**/*"
  ],
  "extends": "expo/tsconfig.base"
}